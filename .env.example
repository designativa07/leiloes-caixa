DATABASE_URL="postgresql://postgres:postgres@localhost:5432/leilaodb?schema=public"

# NextAuth.js (desenvolvimento local — porta do `npm run dev`)
NEXTAUTH_URL="http://localhost:3060"
NEXTAUTH_SECRET="dev-secret-change-in-production-please"
# Em deploy (Coolify, proxy, sslip.io): opcional se trustHost estiver no código
# AUTH_TRUST_HOST=true

# Google OAuth — redirect URI autorizado no Console:
# http://localhost:3060/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend (alertas por email)
RESEND_API_KEY=""
